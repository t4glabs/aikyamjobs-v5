{
  "kind": "collectionType",
  "collectionName": "companies",
  "info": {
    "singularName": "company",
    "pluralName": "companies",
    "displayName": "Company",
    "description": "Companies posting jobs"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "featureImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "excerpt": {
      "type": "text"
    },
    "website": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "size": {
      "type": "string"
    },
    "industry": {
      "type": "string"
    },
    "publishDate": {
      "type": "datetime"
    },
    "author": {
      "type": "string"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "metaTitle": {
      "type": "string",
      "maxLength": 60
    },
    "metaDescription": {
      "type": "text",
      "maxLength": 160
    },
    "socialImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "jobs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::job.job",
      "mappedBy": "company"
    }
  }
}
